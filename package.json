{
  "name": "auto-wms",
  "version": "0.27.0",
  "description": "Auto WMS - WMS 仓储管理系统智能开发辅助工具",
  "main": "src/index.js",
  "bin": {
    "auto": "./bin/cli.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ bin/ tests/",
    "lint:fix": "eslint src/ bin/ tests/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"bin/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"bin/**/*.js\" \"tests/**/*.js\"",
    "sync": "cp commands/wms/*.md .claude/commands/wms/ && echo 'Synced commands/wms/ → .claude/commands/wms/'",
    "prepublishOnly": "npm test",
    "prepare": "npx husky"
  },
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "ai",
    "agents",
    "workflow",
    "wms",
    "warehouse",
    "logistics",
    "automation"
  ],
  "author": "Auto WMS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ouyanglei123/auto-wms"
  },
  "bugs": {
    "url": "https://github.com/ouyanglei123/auto-wms/issues"
  },
  "homepage": "https://github.com/ouyanglei123/auto-wms#readme",
  "files": [
    "bin",
    "src",
    "agents",
    "rules",
    "commands",
    "skills",
    "hooks"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.3.4",
    "inquirer": "^9.2.23",
    "ora": "^8.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "bin/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "vitest": "^4.1.2"
  }
}
